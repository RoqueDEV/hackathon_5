    {
      "id": "node-check-audit-fout",
      "name": "Audit gelukt?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.1,
      "position": [3250, 400],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "cond-audit-ok",
              "leftValue": "={{ $json.applicationId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "node-fout-backend",
      "name": "Stuur foutmelding (500)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [3500, 580],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ \"error\": \"Verwerking mislukt\", \"details\": \"Er is een technische fout opgetreden bij het verwerken van uw aanvraag. Probeer het later opnieuw of neem contact op met de gemeente.\" }) }}",
        "options": {
          "responseCode": 500
        }
      }
    },
    {
