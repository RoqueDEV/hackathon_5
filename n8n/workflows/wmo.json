      "typeVersion": 4.2,
      "position": [3000, 400],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/audit/write",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"citizenToken\": $('Maak burger-token').item.json.token, \"provisionType\": $('Verwijder PII').item.json.provisionType, \"severity\": $('Verwijder PII').item.json.severity, \"route\": $('Bepaal route').item.json.route, \"riskLevel\": $('Vraag AI-advies').item.json.risk_level, \"confidence\": $('Vraag AI-advies').item.json.confidence, \"fairnessFlags\": $('Controleer fairness').item.json.flags, \"finalDecisionStatus\": $('Bepaal route').item.json.route === 'review' ? 'pending_review' : 'auto_approved', \"processingPurpose\": \"wmo_intake\", \"problemSummary\": $('Verwijder PII').item.json.problemSummary, \"aiRecommendation\": $('Vraag AI-advies').item.json.recommendation, \"aiReasoning\": $('Vraag AI-advies').item.json.reasoning, \"aiModel\": $('Vraag AI-advies').item.json.model }) }}",
        "options": {},
        "continueOnFail": true
      }
