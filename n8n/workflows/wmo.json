{
  "name": "WMO Intake",
  "nodes": [
    {
      "id": "note-ontvangst",
      "name": "Sectie: Ontvangst & validatie",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-20, 260],
      "parameters": {
        "content": "## 1. Ontvangst & validatie\nOntvangt aanvraag via webhook en valideert verplichte velden + AVG-toestemming.",
        "height": 340,
        "width": 680,
        "color": 5
      }
    },
    {
      "id": "note-privacy",
      "name": "Sectie: Privacy (AVG)",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [730, 200],
      "parameters": {
        "content": "## 2. Privacy (AVG)\nVervangt citizenId door token en verwijdert PII (naam, adres, geboortedatum) vóór elke AI-call.",
        "height": 300,
        "width": 640,
        "color": 4
      }
    },
    {
      "id": "note-beleid",
      "name": "Sectie: Beleid",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [730, 460],
      "parameters": {
        "content": "## 3. Beleid\nHaalt geldende WMO-regels op voor het gevraagde voorzieningstype.",
        "height": 200,
        "width": 640,
        "color": 3
      }
    },
    {
      "id": "note-ai",
      "name": "Sectie: AI-advies",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1480, 260],
      "parameters": {
        "content": "## 4. AI-advies (EU AI Act, hoog risico)\nStub-LLM genereert advies, onderbouwing, vertrouwensscore. Volledig gelogd: model, input-hash, output.",
        "height": 300,
        "width": 680,
        "color": 6
      }
    },
    {
      "id": "note-fairness",
      "name": "Sectie: Fairness & routing",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [2230, 260],
      "parameters": {
        "content": "## 5. Fairness & routing\nDetecteert verboden termen en bepaalt of mens-in-de-loop nodig is (severity hoog, lage confidence, fairness-vlag, of meervoudige problematiek).",
        "height": 300,
        "width": 780,
        "color": 2
      }
    },
    {
      "id": "note-audit",
      "name": "Sectie: Audit & burgerbericht",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [3080, 140],
      "parameters": {
        "content": "## 6. Audit & burgerbericht\nPersistert in audit-DB (90 dagen bewaartermijn) en stuurt transparant Nederlands B1-bericht terug.",
        "height": 540,
        "width": 1260,
        "color": 1
      }
    },
    {
      "id": "node-webhook",
      "name": "Ontvang aanvraag",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [0, 400],
      "webhookId": "wmo-intake-webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "wmo-intake",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "node-valideer",
      "name": "Valideer aanvraag",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [250, 400],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/applications/validate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-is-valide",
      "name": "Aanvraag geldig?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.1,
      "position": [500, 400],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "cond-valid",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "node-fout-validatie",
      "name": "Stuur foutmelding (400)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [750, 600],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ \"error\": \"Validatie mislukt\", \"errors\": $json.errors || [], \"message\": \"Uw aanvraag kan niet worden verwerkt. Controleer of u toestemming heeft gegeven (consentForAI=true) en alle verplichte velden heeft ingevuld.\" }) }}",
        "options": {
          "responseCode": 400
        }
      }
    },
    {
      "id": "node-pseudonimiseer",
      "name": "Maak burger-token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 300],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/pseudonymize",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"citizenId\": $('Ontvang aanvraag').item.json.body.citizenId }) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-minimaliseer",
      "name": "Verwijder PII",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/minimize",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($('Ontvang aanvraag').item.json.body) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-haal-beleid-op",
      "name": "Haal WMO-beleid op",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 500],
      "parameters": {
        "method": "GET",
        "url": "=http://backend:8000/policy/{{ $('Ontvang aanvraag').item.json.body.provisionType }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-merge-privacy-beleid",
      "name": "Combineer privacy + beleid",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.1,
      "position": [1250, 400],
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      }
    },
    {
      "id": "node-bouw-ai-context",
      "name": "Bouw AI-context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [1500, 400],
      "parameters": {
        "mode": "manual",
        "includeOtherFields": false,
        "fields": {
          "values": [
            {
              "name": "citizenToken",
              "type": "stringValue",
              "stringValue": "={{ $('Maak burger-token').item.json.token }}"
            },
            {
              "name": "provisionType",
              "type": "stringValue",
              "stringValue": "={{ $('Verwijder PII').item.json.provisionType }}"
            },
            {
              "name": "ageGroup",
              "type": "stringValue",
              "stringValue": "={{ $('Verwijder PII').item.json.ageGroup }}"
            },
            {
              "name": "severity",
              "type": "stringValue",
              "stringValue": "={{ $('Verwijder PII').item.json.severity }}"
            },
            {
              "name": "multipleProblems",
              "type": "booleanValue",
              "booleanValue": "={{ $('Verwijder PII').item.json.multipleProblems }}"
            },
            {
              "name": "problemSummary",
              "type": "stringValue",
              "stringValue": "={{ $('Verwijder PII').item.json.problemSummary }}"
            },
            {
              "name": "policy",
              "type": "objectValue",
              "objectValue": "={{ $('Haal WMO-beleid op').item.json }}"
            }
          ]
        }
      }
    },
    {
      "id": "node-ai-advies",
      "name": "Vraag AI-advies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1750, 400],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/ai/recommend",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-fairness-check",
      "name": "Controleer fairness",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 400],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/fairness/check",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($('Vraag AI-advies').item.json) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-bepaal-route",
      "name": "Bepaal route",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2250, 400],
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/route/decide",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"severity\": $('Verwijder PII').item.json.severity, \"multipleProblems\": $('Verwijder PII').item.json.multipleProblems, \"risk_level\": $('Vraag AI-advies').item.json.risk_level, \"fairness_flags\": $('Controleer fairness').item.json.flags, \"confidence\": $('Vraag AI-advies').item.json.confidence, \"consentForAI\": $('Ontvang aanvraag').item.json.body.consentForAI }) }}",
        "options": {},
        "continueOnFail": true
      }
    },
    {
      "id": "node-routeer-beslissing",
      "name": "Routeer beslissing",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [2500, 400],
      "parameters": {
        "mode": "rules",
        "dataType": "string",
        "value1": "={{ $json.route }}",
        "rules": {
          "rules": [
            {
              "operation": "equal",
              "value2": "auto",
              "output": 0
            },
            {
              "operation": "equal",
              "value2": "review",
              "output": 1
            }
          ]
        },
        "fallbackOutput": 2
      }
    },
    {
      "id": "node-bouw-bericht-auto",
      "name": "Bouw burgerbericht (auto)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [2750, 260],
      "parameters": {
        "mode": "manual",
        "includeOtherFields": false,
        "fields": {
          "values": [
            {
              "name": "citizenMessage",
              "type": "stringValue",
              "stringValue": "Uw WMO-aanvraag is ontvangen en automatisch beoordeeld. Bij de beoordeling is AI-ondersteuning gebruikt om uw aanvraag voor te bereiden. U ontvangt binnen de wettelijke termijn een officieel besluit."
            }
          ]
        }
      }
    },
    {
      "id": "node-bouw-bericht-review",
      "name": "Bouw burgerbericht (review)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [2750, 400],
      "parameters": {
        "mode": "manual",
        "includeOtherFields": false,
        "fields": {
          "values": [
            {
              "name": "citizenMessage",
              "type": "stringValue",
              "stringValue": "Uw WMO-aanvraag is ontvangen. Bij de beoordeling is AI-ondersteuning gebruikt om uw aanvraag voor te bereiden. Een medewerker van de gemeente kijkt mee en neemt uw aanvraag zorgvuldig door. U ontvangt zo spoedig mogelijk bericht."
            }
          ]
        }
      }
    },
    {
      "id": "node-bouw-bericht-rejected",
      "name": "Bouw burgerbericht (afgewezen)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [2750, 540],
      "parameters": {
        "mode": "manual",
        "includeOtherFields": false,
        "fields": {
          "values": [
            {
              "name": "citizenMessage",
              "type": "stringValue",
              "stringValue": "Uw WMO-aanvraag kan helaas niet worden verwerkt. Neem contact op met de gemeente voor een persoonlijke beoordeling."
            }
          ]
        }
      }
    },
    {
      "id": "node-schrijf-audit",
      "name": "Schrijf audit-log",
